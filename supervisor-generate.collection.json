            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"{{defaultSupervisorId}}\",\n  \"identityType\": \"employee\"\n}"
            },
            "url": { "raw": "{{baseUrl}}{{basePath}}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing token returns 401 or 403', function () {",
                  "  pm.expect([401,403]).to.include(pm.response.code);",
                  "});",
                  "pm.test('No stack trace leakage', function () {",
                  "  const t = pm.response.text().toLowerCase();",
                  "  ['stacktrace','exception at','sqlstate'].forEach(x => pm.expect(t.includes(x)).to.eql(false));",

                  "  pm.expect((pm.response.code >= 200 && pm.response.code < 300) || pm.response.code === 429).to.eql(true);",
                  "});",
                  "pm.test('Retry-After present when throttled', function () {",
                  "  if (pm.response.code === 429) {",
                  "    pm.expect(pm.response.headers.has('Retry-After')).to.eql(true);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }

{
  "info": {
    "name": "Supervisor Generate API - Security + Functional Suite",
    "_postman_id": "d2d95dfb-bdaf-4f65-a8dc-4a5f8f5477c2",
    "description": "Automated tests for correctness, auth, validation, abuse resistance, and rate limiting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.credentials.dev.app.hyland.com" },
    { "key": "basePath", "value": "/integration/v1/identity/supervisor/generate" },
    { "key": "challengePath", "value": "/integration/v1/identity/supervisor/entityId/challenge" },
    { "key": "revokePath", "value": "/integration/v1/identity/supervisor/entityId/revoke" },
    { "key": "handshakePath", "value": "/integration/v1/identity/supervisor/handshake" },
    { "key": "didA", "value": "foo" },
    { "key": "didB", "value": "bar" },
    { "key": "validToken", "value": "REPLACE_VALID_TOKEN" },
    { "key": "invalidToken", "value": "abc.def.ghi" },
    { "key": "expiredToken", "value": "REPLACE_EXPIRED_TOKEN" },
    { "key": "wrongScopeToken", "value": "REPLACE_WRONG_SCOPE_TOKEN" },
    { "key": "tenantA", "value": "tenant-a" },
    { "key": "tenantB", "value": "tenant-b" },
    { "key": "defaultSupervisorId", "value": "SUP-001" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const expected = '/integration/v1/identity/supervisor/generate';",
          "const actual = pm.variables.get('basePath') || '';",
          "if (actual !== expected) {",
          "  throw new Error(`Invalid basePath: ${actual}. Expected: ${expected}`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Contract + Happy Path",
      "item": [
        {
          "name": "TC-CON-001 Happy Path",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{validToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"{{defaultSupervisorId}}\",\n  \"identityType\": \"employee\",\n  \"context\": {\n    \"tenantId\": \"{{tenantA}}\",\n    \"requestedBy\": \"qa-automation\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{basePath}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{basePath}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Content-Type is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json');",
                  "});",
                  "pm.test('Response does not expose sensitive fields', function () {",
                  "  const text = pm.response.text().toLowerCase();",
                  "  ['password','secret','privatekey'].forEach(k => pm.expect(text.includes('\\\"' + k + '\\\"')).to.eql(false));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {

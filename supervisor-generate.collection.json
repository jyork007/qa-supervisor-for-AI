    {
      "name": "05 - Security Abuse Checks",
      "item": [
        {
          "name": "TC-SEC-001 Injection Payload",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{validToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"' OR '1'='1\",\n  \"identityType\": \"employee\",\n  \"context\": { \"tenantId\": \"{{tenantA}}\" }\n}"
            },
            "url": { "raw": "{{baseUrl}}{{basePath}}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Injection attempt is rejected or safely handled', function () {",
                  "  pm.expect([400,401,403,422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('No internals leaked in response', function () {",
                  "  const t = pm.response.text().toLowerCase();",
                  "  ['sql','stacktrace','exception at','internal server error at'].forEach(x => pm.expect(t.includes(x)).to.eql(false));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-SEC-002 Mass Assignment Attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{validToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"{{defaultSupervisorId}}\",\n  \"identityType\": \"employee\",\n  \"isAdmin\": true,\n  \"role\": \"superadmin\",\n  \"permissions\": [\"*\"],\n  \"context\": { \"tenantId\": \"{{tenantA}}\" }\n}"
            },
            "url": { "raw": "{{baseUrl}}{{basePath}}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Mass assignment does not grant privilege', function () {",
                  "  pm.expect([200,201,400,403,422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response should not reflect dangerous privilege fields', function () {",
                  "  const txt = pm.response.text().toLowerCase();",
                  "  pm.expect(txt.includes('\\\"superadmin\\\"')).to.eql(false);",
                  "  pm.expect(txt.includes('\\\"permissions\\\"')).to.eql(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
